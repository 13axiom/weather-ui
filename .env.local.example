# Copy this file to .env.local and set your values.
# .env.local is in .gitignore — never commit real values.

# URL of the Go weather-api backend (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8080

# URL of the Go races-api backend (no trailing slash)
NEXT_PUBLIC_RACES_API_URL=http://localhost:8081

# Internal API key — must match INTERNAL_API_KEY in weather-api/.env and races-api/.env
# This protects the /api/v1/air/* and /api/v1/races endpoints.
# Generate with: openssl rand -hex 32
# Leave empty to skip auth (fine for local dev when server also has empty key).
NEXT_PUBLIC_INTERNAL_KEY=
